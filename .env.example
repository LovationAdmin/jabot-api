# JABOT API — Variables d'environnement

# Base de donnees PostgreSQL (async)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/jabot_db

# Redis (cache OTP, rate-limiting)
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
# 30 jours + session glissante (token reemis a chaque /me)
ACCESS_TOKEN_EXPIRE_DAYS=30

# Chiffrement des champs sensibles (telephone, dates, ville) au repos.
# Generer une cle Fernet :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Plusieurs cles separees par des virgules => rotation (1re = chiffrement).
# Vide => chiffrement desactive (no-op, dev uniquement).
ENCRYPTION_KEYS=
# Cle HMAC pour le hash deterministe du telephone (lookup sans dechiffrer).
# Doit rester STABLE et secrete (sinon les utilisateurs ne sont plus retrouves).
PHONE_HMAC_KEY=change-me-stable-secret

# CORS — URL du frontend
# En local : http://localhost:3000
# En production (Render), definir : https://www.jabotai.com
FRONTEND_URL=http://localhost:3000

ENVIRONMENT=development

# SMS OTP — Termii (fournisseur principal)
# Sender ID « Lovation » approuvé par Termii pour la route internationale
# France + Sénégal. Pour ajouter un pays (ex. Côte d'Ivoire), demander
# l'activation via le groupe de support Termii avant d'envoyer.
TERMII_API_KEY=
TERMII_SENDER_ID=Lovation

# SMS OTP — Brevo (secours, le moins cher pour la France/EU)
BREVO_API_KEY=
BREVO_SENDER=JABOT

# SMS OTP — Africa's Talking (3e recours)
# Remplacer sandbox par votre username production pour envoyer de vrais SMS.
AFRICAS_TALKING_API_KEY=your-api-key
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_SENDER_ID=JABOT

# SMS OTP — Vonage (dernier recours, laisser vide pour désactiver)
VONAGE_API_KEY=
VONAGE_API_SECRET=

# Mode dev SMS : true => le code OTP est retourné dans la réponse (dev_code).
# Ne jamais activer en production.
SMS_DEV_MODE=true

# Quota d'envoi par numéro — EXIGENCE TERMII (route internationale) :
# maximum 2 envois vers un même numéro par 24 h, sinon le trafic est classé
# spam et facturé. Ne pas augmenter sans accord écrit de Termii.
SMS_MAX_PER_PHONE_PER_DAY=2
# Délai minimum (secondes) entre deux envois vers le même numéro.
SMS_PHONE_COOLDOWN_SECONDS=60

# Invitations par SMS (lien + code), envoyées via la cascade fournisseurs.
# false en local (le code d'invitation est alors retourné dans la réponse) ;
# true en production (render.yaml). Consomme le quota SMS par numéro.
INVITATION_ENABLED=false

# Cloudinary (stockage medias)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
