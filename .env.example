# JABOT API — Variables d'environnement

# Base de donnees PostgreSQL (async)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/jabot_db

# Redis (cache OTP, rate-limiting)
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
# 30 jours + session glissante (token reemis a chaque /me)
ACCESS_TOKEN_EXPIRE_DAYS=30

# Chiffrement des champs sensibles (telephone, dates, ville) au repos.
# Generer une cle Fernet :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Plusieurs cles separees par des virgules => rotation (1re = chiffrement).
# Vide => chiffrement desactive (no-op, dev uniquement).
ENCRYPTION_KEYS=
# Cle HMAC pour le hash deterministe du telephone (lookup sans dechiffrer).
# Doit rester STABLE et secrete (sinon les utilisateurs ne sont plus retrouves).
PHONE_HMAC_KEY=change-me-stable-secret

# CORS — URL du frontend
# En local : http://localhost:3000
# En production (Render), definir : https://www.jabotai.com
FRONTEND_URL=http://localhost:3000

ENVIRONMENT=development

# SMS OTP — Africa's Talking (fournisseur principal)
# Remplacer sandbox par votre username production pour envoyer de vrais SMS.
AFRICAS_TALKING_API_KEY=your-api-key
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_SENDER_ID=JABOT

# SMS OTP — Vonage (fournisseur de secours, laisser vide pour désactiver)
VONAGE_API_KEY=
VONAGE_API_SECRET=

# Mode dev SMS : true => le code OTP est retourné dans la réponse (dev_code).
# Ne jamais activer en production.
SMS_DEV_MODE=true

# Cloudinary (stockage medias)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
